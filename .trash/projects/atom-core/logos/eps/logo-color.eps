%%EndSetup
%%Page: 1 1
%%BeginPageSetup
%%PageBoundingBox: 0 0 1000 1000
%%EndPageSetup
q 0 0 1000 1000 rectclip
1 0 0 -1 0 1000 cm q
0.0666667 g
0 0 1000 1000 rectfill
Q q
150 106 700 788 re W n
q
150 106 700 788 re W n
